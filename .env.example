# Anthropic
ANTHROPIC_API_KEY=

# Postgres (dev default uses compose service name inside containers)
POSTGRES_USER=travelbuddy
POSTGRES_PASSWORD=travelbuddy
POSTGRES_DB=travelbuddy
DATABASE_URL=postgresql+asyncpg://travelbuddy:travelbuddy@localhost:5433/travelbuddy

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALG=HS256
JWT_EXP_HOURS=72

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173

# Telegram
TELEGRAM_BOT_TOKEN=

# Whisper STT fallback (set USE_WHISPER=false to disable the route)
USE_WHISPER=true
STT_MODEL=small

# RAG seed
SEED_RAG_ON_STARTUP=true
