# ── Required ─────────────────────────────────────────────────────────
# Anthropic — needed for the agent to work at all
ANTHROPIC_API_KEY=

# Postgres — no defaults on purpose. Generate with:
#   openssl rand -base64 24 | tr -d '/+=' | head -c 28
POSTGRES_USER=travelbuddy
POSTGRES_PASSWORD=generate-me-please
POSTGRES_DB=travelbuddy
# DATABASE_URL is used when running backend/bot OUTSIDE docker compose
# (make backend-dev, alembic, pytest). Inside compose the URL is rebuilt
# automatically from POSTGRES_* to point at the service-internal hostname.
DATABASE_URL=postgresql+asyncpg://travelbuddy:generate-me-please@localhost:5433/travelbuddy

# Auth — generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-string
JWT_ALG=HS256
JWT_EXP_HOURS=72

# CORS (comma-separated)
CORS_ORIGINS=http://localhost:5173

# Telegram
TELEGRAM_BOT_TOKEN=
# The bot's public @username (used to build t.me deep-links in the UI)
TELEGRAM_BOT_USERNAME=your_bot_username

# Whisper STT fallback (set USE_WHISPER=false to disable the route)
USE_WHISPER=true
STT_MODEL=small

# RAG seed
SEED_RAG_ON_STARTUP=true

# Dev escape hatches for corporate MITM TLS proxies (Yandex etc.)
# 1) Preferred: point httpx/openssl at a combined CA bundle
#    SSL_CERT_FILE=/path/to/yandex+certifi.pem
# 2) Last resort (NOT for production): bypass verification entirely
#    ANTHROPIC_DISABLE_TLS_VERIFY=true
ANTHROPIC_DISABLE_TLS_VERIFY=false
